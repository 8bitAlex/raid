# yaml-language-server: $schema=https://raw.githubusercontent.com/8bitalex/raid/main/schemas/raid-repo.schema.json
#
# Raid Repository Configuration
# A raid.yaml file lives in the root of a repository and defines per-repo
# environments, install steps, and custom commands. When a profile runs
# `raid env` or `raid install`, each repo's raid.yaml is also evaluated.
#
# VS Code users: install the Red Hat YAML extension for automatic schema
# validation and autocomplete:
# https://marketplace.visualstudio.com/items?itemName=redhat.vscode-yaml
# The schema is published to SchemaStore, so raid.yaml files are
# automatically associated -- no manual $schema comment required.

# name: my-service
# branch: main

