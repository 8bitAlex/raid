{
  // This file is not used in compilation. It is here just for a nice editor experience.
  // Inlined from @docusaurus/tsconfig so we can drop the deprecated `baseUrl` option.
  // Paths are resolved relative to this tsconfig (TS 5.0+ behavior) without baseUrl.
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "noEmit": true,
    "paths": {
      "@site/*": ["./*"]
    },
    "skipLibCheck": true
  },
  "exclude": [".docusaurus", "build", "**/__tests__/**", "**/*.test.ts"]
}
